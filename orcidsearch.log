194                 a.search_first,
195                 a.search_last,
196                 a.search_label,
197                 a.name_weight,
198                 tranwrd(strip(a.search_first),' ','%20') as q_first length=200,
199                 tranwrd(strip(a.search_last),' ','%20')  as q_last  length=200,
200                 a.orcid_identifier_path as orcid_id length=25
201          from work.orcid_hits_all a
202          where not missing(a.orcid_identifier_path);
