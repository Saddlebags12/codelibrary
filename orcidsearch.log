290           7) Compute score + confidence + best match
291           ----------------------------------------- */
292        proc sql;
293          create table work.scored_candidates2 as
294          select a.*,
295                 b.candidate_n,
296                 (30
297                  + case when a.institution_match=1 then 25 else 0 end
298                  + min(a.name_weight, 35)
299                  + case when b.candidate_n=1 then 10 else 0 end
300                  + case when a.search_label='PRIMARY' then 5 else 0 end
301                 ) as score
302          from work.scored_candidates a
303          left join work.candidate_counts b
304            on a.cpfp_id=b.cpfp_id;
NOTE: Table WORK.SCORED_CANDIDATES2 created, with 0 rows and 11 columns.

