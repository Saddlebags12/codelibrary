101        %macro get_orcid_candidates();
102        
103          data work.orcid_hits_all;
104            length cpfp_id $50 first_name last_name $100 search_first search_last $100
105                   search_label $40 name_weight 8 orcid_identifier_path $25;
106            stop;
107          run;
108        
7 The SAS System                                                                                                       14:28 Tuesday, April 14, 2026

109          proc sql noprint;
110            select count(*) into :nobs trimmed
111            from work.names_q;
112          quit;
113        
114          %do i = 1 %to &nobs;
115        
116            data _null_;
117              set work.names_q(firstobs=&i obs=&i);
118              call symputx('v_cpfp_id', cpfp_id, 'l');
119              call symputx('v_first',   first_name, 'l');
120              call symputx('v_last',    last_name, 'l');
121              call symputx('v_sfirst',  search_first, 'l');
122              call symputx('v_slast',   search_last, 'l');
123              call symputx('v_label',   search_label, 'l');
124              call symputx('v_weight',  name_weight, 'l');
125              call symputx('v_url',     query_url, 'l');
126            run;
127        
128            filename resp temp;
129        
130            proc http
131              method="GET"
132              url="%superq(v_url)"
133              out=resp;
134              headers "Accept"="application/json";
135            run;
136        
137            data work.orcid_hits_one;
138              length cpfp_id $50 first_name last_name search_first search_last $100
139                     search_label $40 name_weight 8 line $32767 orcid_identifier_path $25;
140              retain re;
141              if _n_=1 then re = prxparse('/\b\d{4}-\d{4}-\d{4}-\d{3}[0-9X]\b/');
142        
143              cpfp_id    = symget('v_cpfp_id');
144              first_name = symget('v_first');
145              last_name  = symget('v_last');
146              search_first = symget('v_sfirst');
147              search_last  = symget('v_slast');
148              search_label = symget('v_label');
149              name_weight  = input(symget('v_weight'), best12.);
150        
151              infile resp lrecl=32767 truncover;
152              input line $char32767.;
153        
154              start = 1; stop = length(line);
155              call prxnext(re, start, stop, line, pos, len);
156              do while (pos > 0);
157                orcid_identifier_path = substr(line, pos, len);
158                output;
159                call prxnext(re, start, stop, line, pos, len);
160              end;
161        
162              keep cpfp_id first_name last_name search_first search_last search_label name_weight orcid_identifier_path;
163            run;
164        
165            proc sort data=work.orcid_hits_one nodupkey;
166              by cpfp_id first_name last_name search_first search_last orcid_identifier_path;
167            run;
168        
169            proc sql noprint;
170              select count(*) into :hit_n trimmed
