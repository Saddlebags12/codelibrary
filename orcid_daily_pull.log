36          | STEP 2: CLEAN ORCID
37          *-----------------------------*/
38         data alumni_clean;
39             set alumni_raw;
40         
41             length orcid_clean $19;
42         
43             /* Normalize ORCID */
44             orcid_clean = compress(upcase(orcid), ' ');
45             orcid_clean = tranwrd(orcid_clean, 'HTTP://ORCID.ORG/', '');
46             orcid_clean = tranwrd(orcid_clean, 'HTTPS://ORCID.ORG/', '');
47         
48         run;

