8          /* helper: assert table has rows */
9          %macro assert_has_rows(ds=, msg=);
10             %local dsid nobs rc;
11             %let dsid = %sysfunc(open(&ds));
12             %if &dsid %then %do;
13                 %let nobs = %sysfunc(attrn(&dsid,nobs));
14                 %let rc   = %sysfunc(close(&dsid));
15             %end;
16             %else %let nobs=0;
17         
18             %if &nobs=0 %then %do;
19                 %put ERRANT: &msg;
20                 %return;
21             %end;
22         %mend;
