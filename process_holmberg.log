24         /* parse one folder into one output dataset */
25         %macro parse_folder(subdir=, outds=, mapname=, member_condition=);
26             %local folder mapfile n_xml i this_file this_member clean_file out_created;
27         
28             %let folder  = &base_dir/&subdir;
29             %let mapfile = &base_dir/&mapname;
30             %if %superq(member_condition)= %then %let member_condition=1=1;
2 The SAS System                                                                                                     10:54 Wednesday, April 29, 2026

31         
32             filename xmldir "&folder";
33         
34             data work._xml_files;
35                 length file_name $256 file_path $600;
36                 did = dopen('xmldir');
37                 if did <= 0 then do;
38                     put "ERRANT: Could not open folder &folder";
39                     stop;
40                 end;
41         
42                 do i = 1 to dnum(did);
43                     file_name = dread(did, i);
44                     if lowcase(scan(file_name, -1, '.'))='xml' then do;
45                         file_path = cats("&folder/", file_name);
46                         output;
47                     end;
48                 end;
49         
50                 rc = dclose(did);
51                 drop did i rc;
52             run;
53         
54             proc sql noprint;
55                 select count(*) into :n_xml trimmed
56                 from work._xml_files;
57             quit;
58         
59             %if %sysevalf(%superq(n_xml)=,boolean) or &n_xml=0 %then %do;
60                 %put NOTE: Skipping &subdir - no XML files found in &folder..;
61                 %goto parse_folder_done;
62             %end;
63         
64             proc sql noprint;
65                 select file_path into :first_xml trimmed
66                 from work._xml_files(obs=1);
67             quit;
68         
69             libname xfirst xmlv2 "&first_xml"
